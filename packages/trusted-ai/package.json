    "@taicc/data-layer": "workspace:*",
    "@taicc/fireblocks-client": "workspace:*",
    "@taicc/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
