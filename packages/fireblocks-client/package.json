{
  "name": "@taicc/fireblocks-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fireblocks/ts-sdk": "^12.0.0",
    "@taicc/audit": "workspace:*",
    "@taicc/shared-types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
