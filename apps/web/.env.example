/**
 * Web app — browser-safe env vars only.
 * Never put Fireblocks keys, JWT secrets, or LLM API keys here.
 */
# Public API base URL (set at build time on Vercel)
VITE_API_URL=https://api.your-domain.com

# Required in production: same value as API_VIEWER_TOKEN on Render (read-only dashboard access).
# VITE_API_TOKEN=

# Optional: same value as Render SANDBOX_ADMIN_TOKEN — enables Generate Sandbox Activity UI only.
# VITE_SANDBOX_ADMIN_TOKEN=
