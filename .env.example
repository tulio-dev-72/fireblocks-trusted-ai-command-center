# ── Application ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Data Mode (mutually exclusive — see docs/architecture/DATA_LAYER.md) ──
# Mode 1 — Real Fireblocks sandbox (default):
DEMO_MODE=false
REAL_FIREBLOCKS=true
HYBRID_MODE=false

# Mode 2 — Demo seed (local UI only, never production):
# DEMO_MODE=true
# REAL_FIREBLOCKS=false
# HYBRID_MODE=false

# Mode 3 — Hybrid (real metadata + labeled mocks):
# DEMO_MODE=false
# REAL_FIREBLOCKS=true
# HYBRID_MODE=true

# ── API Gateway ──────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGINS=http://localhost:5173

# ── Command Center UI ────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── MCP Server ─────────────────────────────────────────────────
MCP_PORT=3100
MCP_SERVER_NAME=fireblocks-trusted-ai

# ── Worker ─────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
REDIS_URL=redis://localhost:6379

# ── Auth / Identity ────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-kms
JWT_ISSUER=fireblocks-trusted-ai-command-center
JWT_AUDIENCE=command-center
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# ── Fireblocks (required for REAL_FIREBLOCKS and HYBRID modes) ─
FIREBLOCKS_API_KEY=
FIREBLOCKS_SECRET_KEY_PATH=./fireblocks_secret.key
FIREBLOCKS_BASE_PATH=https://sandbox-api.fireblocks.io/v1
FIREBLOCKS_WORKSPACE_ID=
FIREBLOCKS_WEBHOOK_ID=

# ── Policy Engine ──────────────────────────────────────────────
POLICY_ENFORCEMENT_MODE=enforce
POLICY_DEFAULT_ACTION=deny

# ── Audit ──────────────────────────────────────────────────────
AUDIT_STORAGE=postgres
DATABASE_URL=postgresql://taicc:taicc@localhost:5432/taicc

# ── Trusted AI Layer ───────────────────────────────────────────
# AI_PROVIDER: openai | anthropic | auto (default — OpenAI first, then Anthropic)
AI_PROVIDER=auto
AI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# When no API key is set, workflows use local evidence-grounded synthesis.
AI_PROMPT_LOGGING=true

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=trusted-ai-command-center
