# ── Application ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Data Mode ────────────────────────────────────────────────
DEMO_MODE=false
REAL_FIREBLOCKS=true
HYBRID_MODE=false

# ── API (backend — Render/Railway/Docker) ────────────────────
API_PORT=3001
API_HOST=0.0.0.0
# Local dev only — comma-separated origins
API_CORS_ORIGINS=http://localhost:5173
# Production: set to your Vercel URL (single origin; overrides API_CORS_ORIGINS)
# PUBLIC_FRONTEND_URL=https://your-app.vercel.app

# ── Web (frontend — Vercel only; see apps/web/.env.example) ──
# VITE_API_URL=http://localhost:3001

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-kms
JWT_ISSUER=fireblocks-trusted-ai-command-center
JWT_AUDIENCE=command-center

# ── Fireblocks ───────────────────────────────────────────────
FIREBLOCKS_API_KEY=
# Local: file path. Cloud/production: use FIREBLOCKS_PRIVATE_KEY instead (never commit).
FIREBLOCKS_SECRET_KEY_PATH=./fireblocks_secret.key
# FIREBLOCKS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBLOCKS_BASE_PATH=https://sandbox-api.fireblocks.io/v1
FIREBLOCKS_WORKSPACE_ID=

# ── Audit (Postgres — default) ───────────────────────────────
AUDIT_STORE=postgres
AUDIT_BOOTSTRAP_SCHEMA=true
DATABASE_URL=postgresql://taicc:taicc@localhost:5432/taicc

# ── AI providers (backend only — never expose to Vercel) ─────
AI_PROVIDER=auto
AI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
AI_PROMPT_LOGGING=true

# ── Worker / queue (Upstash in production) ─────────────────────
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5

# ── MCP (optional) ───────────────────────────────────────────
MCP_PORT=3100
